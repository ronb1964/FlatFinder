{
  "expo": {
    "name": "FlatFinder",
    "slug": "flatfinder-rv-leveling",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "flatfinder",
    "primaryColor": "#22c55e",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flatfinder.rvleveling",
      "buildNumber": "5",
      "infoPlist": {
        "NSMotionUsageDescription": "FlatFinder uses motion sensors to detect your RV's tilt for accurate leveling assistance.",
        "UIRequiredDeviceCapabilities": [
          "accelerometer",
          "gyroscope"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.flatfinder.rvleveling",
      "versionCode": 1,
      "permissions": [
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "eas": {
        "projectId": "0c33edf0-e9d4-4f4f-95ef-0636628dcb28"
      }
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store"
    ]
  }
}
